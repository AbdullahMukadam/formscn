{
  "name": "form-registry",
  "version": "0.1.4",
  "description": "Runtime form registry for rendering forms from Zod schemas",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/",
    "check-types": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "@hookform/resolvers": "^3.0.0",
    "date-fns": "^4.0.0",
    "formscn-ui": "^0.1.1",
    "libphonenumber-js": "^1.10.0",
    "lucide-react": "^0.471.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-hook-form": "^7.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@storybook/react": "^10.2.13",
    "@storybook/react-vite": "^10.2.13",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0 || ^19.0.0",
    "@types/react-dom": "^18.2.0 || ^19.0.0",
    "formscn-ui": "^0.1.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwindcss": "^4.1.18",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vite": "^7.3.1"
  },
  "keywords": [
    "react",
    "forms",
    "zod",
    "shadcn",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "storybook": "^10.2.13"
  }
}
