{
  "name": "@formscn/ui",
  "version": "0.1.2",
  "description": "shadcn/ui components for FormsCN",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "style": "./dist/index.css",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles": "./dist/index.css"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/",
    "check-types": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.0.0",
    "class-variance-authority": "^0.7.0 || ^0.8.0",
    "clsx": "^2.0.0 || ^2.1.0",
    "lucide-react": "^0.300.0 || ^0.400.0 || ^0.500.0",
    "react-day-picker": "^8.0.0 || ^9.0.0",
    "tailwind-merge": "^2.0.0 || ^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0 || ^19.0.0",
    "@types/react-dom": "^18.2.0 || ^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "react",
    "ui",
    "shadcn",
    "components",
    "form",
    "input",
    "button",
    "select",
    "checkbox"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AbdullahMukadam/formscn.git"
  }
}